# =============================================================================
# SUPPORTFLOW MULTI-AGENT ROUTER
# Environment variables example
# =============================================================================
# Copy this file to `.env` and replace placeholder values with real credentials.
#
# PowerShell:
# Copy-Item .env.example .env
#
# IMPORTANT:
# - Do not commit `.env`
# - Do not place real API keys in `.env.example`
# - `.env.example` is safe to commit because it only contains placeholders
# =============================================================================


# =============================================================================
# LLM PROVIDER CONFIGURATION
# =============================================================================
# Supported values:
# - openai
# - xai
# - deepseek
#
# This value controls which chat model provider is used by:
# - specialized RAG agents
# - evaluator agent
# - graph workflow calls

LLM_PROVIDER=openai

# Optional fallback provider used if the selected provider is unavailable.
# Usually keep this as openai for local validation.
LLM_FALLBACK_PROVIDER=openai


# =============================================================================
# OPENAI CONFIGURATION
# =============================================================================
# Used for:
# - default chat model
# - embeddings for Chroma vector stores
# - RAG agents
# - evaluator agent

OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini


# =============================================================================
# XAI / GROK CONFIGURATION
# =============================================================================
# Used only when:
# LLM_PROVIDER=xai
# or
# LLM_FALLBACK_PROVIDER=xai

XAI_API_KEY=your-xai-api-key-here
XAI_MODEL=grok-4.3


# =============================================================================
# DEEPSEEK CONFIGURATION
# =============================================================================
# Used only when:
# LLM_PROVIDER=deepseek
# or
# LLM_FALLBACK_PROVIDER=deepseek

DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_MODEL=deepseek-chat


# =============================================================================
# EMBEDDINGS CONFIGURATION
# =============================================================================
# Important:
# Keep this value consistent with the embedding model used to create the
# Chroma vector stores.
#
# If you change this model after creating vectorstores, regenerate them with:
# uv run python -m src.ingestion.ingest_documents

EMBEDDING_MODEL=text-embedding-3-small


# =============================================================================
# LANGFUSE OBSERVABILITY
# =============================================================================
# Used by Stage 6:
# - LangGraph workflow tracing
# - route observability
# - agent execution traces
# - RAG response observability
#
# Used by Stage 7:
# - evaluator score recording
# - quality metrics
# - pass/fail scoring
#
# For Langfuse Cloud, use:
# https://cloud.langfuse.com

LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key-here
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key-here

# LANGFUSE_BASE_URL is used by the current Langfuse SDK configuration.
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# LANGFUSE_HOST is kept for compatibility with the project settings.
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional metadata added to traces and score records.
LANGFUSE_ENVIRONMENT=development
LANGFUSE_RELEASE=supportflow-stage-7


# =============================================================================
# EVALUATOR AGENT CONFIGURATION
# =============================================================================
# Used by Stage 7:
# - evaluator agent
# - quality scoring
# - Langfuse Score API integration
#
# The evaluator scores answers from 1 to 10 across:
# - relevance
# - completeness
# - accuracy
# - groundedness
# - clarity

EVALUATION_PASS_THRESHOLD=7.0

# Supported values:
# - true
# - false
#
# If true, the evaluator attempts to push scores to Langfuse when configured.
# If false, evaluation still runs locally but scores are not recorded in Langfuse.

ENABLE_LANGFUSE_SCORING=true


# =============================================================================
# LOCAL DEVELOPMENT NOTES
# =============================================================================
# Required local validation commands:
#
# Ingestion:
# uv run python -m src.ingestion.ingest_documents
#
# Stage 5 graph validation:
# uv run python -m src.graph.test_graph
#
# Stage 6 Langfuse observability validation:
# uv run python -m src.graph.test_langfuse_observability
#
# Stage 7 evaluator validation:
# uv run python -m src.graph.test_evaluator_agent
# =============================================================================